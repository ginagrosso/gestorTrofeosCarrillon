# Configuración del SDK web de Firebase
# Firebase Console > Configuración del proyecto > Tus apps > SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL base de la API (Cloud Functions)
# Local (emulador):  http://127.0.0.1:5001/<project-id>/<region>/api
# Producción:        https://<region>-<project-id>.cloudfunctions.net/api
VITE_API_URL=

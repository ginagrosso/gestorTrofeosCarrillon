# Plantilla para variables de entorno de PRODUCCIÓN.
# Para desarrollo local con emuladores ya está `.env.development` (incluido en el repo).
#
# Copiar este archivo como `.env` y completar con los datos reales del proyecto:
# Firebase Console > Configuración del proyecto > Tus apps > SDK config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# URL de la API (Cloud Functions) en producción
# https://<region>-<project-id>.cloudfunctions.net/api
VITE_API_URL=
